{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "hardimpactdev/craft-starterkit",
    "type": "project",
    "description": "Craft Starterkit - Laravel + Vue + Inertia application scaffold.",
    "keywords": [
        "laravel",
        "vue",
        "inertia",
        "starterkit"
    ],
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "../../packages/craft-laravel"
        },
        {
            "type": "path",
            "url": "../../packages/waymaker"
        },
        {
            "type": "path",
            "url": "../../packages/laravel-toolbar"
        }
    ],
    "require": {
        "php": "^8.4",
        "filament/filament": "^5.2",
        "hardimpactdev/craft-laravel": "@dev",
        "hardimpactdev/waymaker": "@dev",
        "inertiajs/inertia-laravel": "^3.0@beta",
        "laravel/fortify": "^1.30",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.31",
        "laravel/tinker": "^3.0",
        "laravel/wayfinder": "^0.1.2",
        "spatie/laravel-csp": "^3.8",
        "spatie/laravel-data": "^4.14",
        "spatie/laravel-typescript-transformer": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^v2.1.4",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.21",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nckrtl/laravel-toolbar": "@dev",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.1",
        "pestphp/pest-plugin-browser": "^4.2",
        "pestphp/pest-plugin-drift": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "projektgopher/whisky": "^0.7.4",
        "rector/rector": "^2.0",
        "spatie/pest-plugin-route-testing": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "files": [
            "app/helpers.php"
        ],
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "setup": "@php setup.php",
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "test": "vendor/bin/pest --parallel",
        "lint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse",
        "rector": "vendor/bin/rector",
        "check": "composer test && composer analyse && bunx oxlint@latest && bun run oxfmt --check resources/",
        "fix": "composer rector && composer lint && bunx oxlint@latest --fix --fix-suggestions && bun run oxfmt resources/",
        "available-updates": "composer outdated -D"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
